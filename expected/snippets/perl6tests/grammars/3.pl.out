｢my $x;
$x = 5;
say $x; # 5 

my $y;
$y = $x;
say $y; # 5

my $z;
$z = $x + $y;
say $z; # 10

my $sum;
$sum = 10 + 11 + $x + $y + $z;
say $sum; # 27
｣
